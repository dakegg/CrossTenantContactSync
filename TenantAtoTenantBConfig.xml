<Configuration>
  <Source>
    <TenantId>11111111-1111-1111-1111-111111111111</TenantId>
    <TenantName>TenantA</TenantName>
    <ClientId>22222222-2222-2222-2222-222222222222</ClientId>
    <ClientSecret>YOUR_SOURCE_GRAPH_CLIENT_SECRET</ClientSecret>
  </Source>

  <Target>
    <Organization>hubtenant.onmicrosoft.com</Organization>
    <TenantId>33333333-3333-3333-3333-333333333333</TenantId>
    <TenantName>HubTenant</TenantName>
    <ExoAppId>44444444-4444-4444-4444-444444444444</ExoAppId>
    <ExoCertThumbprint>ABCDEF1234567890ABCDEF1234567890ABCDEF12</ExoCertThumbprint>
  </Target>

  <Runtime>
    <StateRoot>C:\TenantContactSync\State</StateRoot>
    <LogRoot>C:\TenantContactSync\Logs</LogRoot>
    <AppendSourceTenantToDisplayName>true</AppendSourceTenantToDisplayName>
    <AllowUpnFallback>true</AllowUpnFallback>
    <DisableDeletes>false</DisableDeletes>
    <SourceObjectType>User</SourceObjectType>
    <TopUsers>0</TopUsers>
  </Runtime>

  <Filters>
    <IncludeDomains>
      <Domain>tenanta.com</Domain>
      <Domain>subsidiary-a.com</Domain>
    </IncludeDomains>
    <ExcludeDomains>
      <Domain>serviceaccount.tenanta.com</Domain>
    </ExcludeDomains>
  </Filters>
</Configuration>