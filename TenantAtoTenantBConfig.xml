<Configuration>
  <Source>
    <TenantId>xxxxxxxxxxxxxxxxxxxxxxxxxxxxx</TenantId>
    <TenantName>Friendly Name for Source Tenant (this will be added to DisplayName on Target)</TenantName>
    <ClientId>yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy</ClientId>
    <ClientSecret>zzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzz</ClientSecret>
  </Source>

  <Target>
    <Organization>contoso.onmicrosoft.com</Organization>
    <TenantId>aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa</TenantId>
    <TenantName>contoso.onmicrosoft.com</TenantName>
    <ExoAppId>bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb</ExoAppId>
    <ExoCertThumbprint>cccccccccccccccccccccccccccccccccc</ExoCertThumbprint>
  </Target>

  <Runtime>
    <StateRoot>C:\Temp\TenantContactSync\State</StateRoot>
    <LogRoot>C:\Temp\TenantContactSync\Logs</LogRoot>
    <AppendSourceTenantToDisplayName>true</AppendSourceTenantToDisplayName>
    <AllowUpnFallback>true</AllowUpnFallback>
    <DisableDeletes>false</DisableDeletes>
    <SourceObjectType>User</SourceObjectType>
    <TopUsers>0</TopUsers>
    <SeedTargetFromSource></SeedTargetFromSource>
  </Runtime>

<Filters>
  <IncludeDomains>
    <Domain></Domain>
  </IncludeDomains>

  <ExcludeDomains>
    <Domain></Domain>
  </ExcludeDomains>

  <ServiceAccountPatterns>
    <Pattern>^sync_</Pattern>
    <Pattern>^aadconnect</Pattern>
    <Pattern>^msol_</Pattern>
    <Pattern>^svc[-_]</Pattern>
    <Pattern>^service</Pattern>
    <Pattern>azureadconnect</Pattern>
  </ServiceAccountPatterns>

  <AttributeFilters>
  <Filter>
    <ObjectType>User</ObjectType>
    <PropertyPath>onPremisesExtensionAttributes.extensionAttribute9</PropertyPath>
    <Operator>Equals</Operator>
    <Value>DoNotSync</Value>
  </Filter>

  <Filter>
    <ObjectType>Group</ObjectType>
    <PropertyPath>extension_5c9a0521674b41b69a7d81ffb3a43dc5_CreateAsContact</PropertyPath>
    <Operator>Equals</Operator>
    <Value>False</Value>
  </Filter>
</AttributeFilters>

</Filters>

</Configuration>